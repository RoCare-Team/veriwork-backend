NODE_ENV=development
PORT=8080

# Local development
MONGODB_URI=mongodb://localhost:27017/veriwork

# Production (MongoDB Atlas) — set in Vercel Environment Variables
# MONGODB_URI=mongodb+srv://DB_USER:DB_PASSWORD@cluster0.xxxxx.mongodb.net/veriwork?retryWrites=true&w=majority
# If password has special chars (@ # % etc), URL-encode them in the connection string.

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Accept one or more comma-separated frontend origins.
# Example: CORS_ORIGIN=http://localhost:5173,https://app.pagerlook.com
CORS_ORIGIN=http://localhost:5173

# Google OAuth (Employee login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

OTP_MOCK_CODE=123456
OTP_EXPIRES_MINUTES=10

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=pager-look

# ─────────────────────────────────────────────────────────────────────────────
# Email / SMTP  —  ALL outgoing system email uses ONLY these variables.
# The app code is provider-agnostic: to move from Gmail to Amazon SES (or change
# the sender to verification@ / support@ / noreply@pagerlook.com) change ONLY the
# values below — no code changes required. Never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# --- Development: Gmail SMTP ---
# 1. Enable 2-Step Verification on skc26601@gmail.com
# 2. Create an "App password" (Google Account > Security > App passwords)
# 3. Paste the 16-char app password (no spaces) into SMTP_PASS below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=raftaarnews02@gmail.com
SMTP_PASS=your-16-char-gmail-app-password
SMTP_FROM=PagerLook <raftaarnews02@gmail.com>
# SMTP_REPLY_TO=support@pagerlook.com

# --- Production: swap values only, e.g. Amazon SES ---
# SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=<SES-SMTP-username>
# SMTP_PASS=<SES-SMTP-password>
# SMTP_FROM=PagerLook <verification@pagerlook.com>

# --- Optional email branding (used by the shared HTML template) ---
# EMAIL_BRAND_NAME=PagerLook
# EMAIL_BRAND_TAGLINE=Verify. Trust. Grow.
# EMAIL_BRAND_COLOR=#1e3a8a
# EMAIL_LOGO_URL=https://pagerlook.com/pagerLookLogo.png
# EMAIL_SUPPORT=support@pagerlook.com
