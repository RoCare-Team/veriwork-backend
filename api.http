GET {{baseUrl}}/employee/jobs
Authorization: Bearer {{employeeToken}}

###

GET {{baseUrl}}/employee/vault
Authorization: Bearer {{employeeToken}}

###

GET {{baseUrl}}/employee/activity
Authorization: Bearer {{employeeToken}}

###

GET {{baseUrl}}/employee/activity?filter=requests
Authorization: Bearer {{employeeToken}}

###

GET {{baseUrl}}/employee/invitations
Authorization: Bearer {{employeeToken}}

###

POST {{baseUrl}}/employee/invitations/{{invitationId}}/accept
Authorization: Bearer {{employeeToken}}

###

POST {{baseUrl}}/employee/invitations/{{invitationId}}/reject
Authorization: Bearer {{employeeToken}}

###

GET {{baseUrl}}/employee/access-requests
Authorization: Bearer {{employeeToken}}

###

POST {{baseUrl}}/employee/access-request/{{accessRequestId}}/approve
Authorization: Bearer {{employeeToken}}

###

POST {{baseUrl}}/employee/access-request/{{accessRequestId}}/reject
Authorization: Bearer {{employeeToken}}

